{
    "name": "single-web-test-automation-framework",
    "version": "1.0.0",
    "description": "Common web projects test automation framework",
    "main": "index.js",
    "repository": "https://github.com/abcxxx.git",
    "author": "VinsanityShred",
    "license": "ISC",
    "scripts": {
        "open:le:vshred": "cypress open --project ./src/LaravelEcommerce/LE_Vshred --config-file le.vshred.config.ts",
        "test:le:vshred:smoke": "cypress run --project ./src/LaravelEcommerce/LE_Vshred --config-file le.vshred.config.ts --env tags=@smoke,filterSpecs=true --record --key 0595bb44-0bb7-4c39-9089-ca4b97ea5184 --parallel",
        "test:le:vshred:beta": "cypress run --project ./src/LaravelEcommerce/LE_Vshred --config-file le.vshred.config.ts --env tags=@beta,filterSpecs=true --record --key 0595bb44-0bb7-4c39-9089-ca4b97ea5184 --parallel",
        "test:le:vshred:all": "cypress run --project ./src/LaravelEcommerce/LE_Vshred --config-file le.vshred.config.ts --record --key 0595bb44-0bb7-4c39-9089-ca4b97ea5184 --parallel",
        "open:le:marketing": "cypress open --project ./src/LaravelEcommerce/Marketing_Funnels --config-file le.marketing.config.ts",
        "test:le:marketing:smoke": "cypress run --project ./src/LaravelEcommerce/Marketing_Funnels --config-file le.marketing.config.ts --env tags=@smoke,filterSpecs=true --record --key 7879e625-7dc2-4450-821c-4d0f95c4ed33 --parallel",
        "test:le:marketing:all": "cypress run --project ./src/LaravelEcommerce/Marketing_Funnels --config-file le.marketing.config.ts --record --key 7879e625-7dc2-4450-821c-4d0f95c4ed33  --parallel",
        "open:le:sn": "cypress open --project ./src/LaravelEcommerce/SculptNation --config-file le.sn.config.ts",
        "test:le:sn": "cypress run --project ./src/LaravelEcommerce/SculptNation --config-file le.sn.config.ts --record --key 715f0e40-2893-4996-8689-202e94bf2ae2 --parallel",
        "test:le:sn:github:actions": "cypress run --project ./src/LaravelEcommerce/SculptNation --config-file le.sn.github.actions.config.ts",
        "open:vstt": "cypress open --project ./src/Vshred/Vshred_TrainerTool --config-file vs.tt.config.ts",
        "test:vstt:smoke": "cypress run --project ./src/Vshred/Vshred_TrainerTool --config-file vs.tt.config.ts --env tags=@smoke,filterSpecs=true --record --key f48ea33b-7d72-4a9a-b6ad-d28612774511 --parallel",
        "test:vstt:beta": "cypress run --project ./src/Vshred/Vshred_TrainerTool --config-file vs.tt.config.ts --env tags=@beta,filterSpecs=true --record --key f48ea33b-7d72-4a9a-b6ad-d28612774511 --parallel",
        "test:vstt:all": "cypress run --project ./src/Vshred/Vshred_TrainerTool --config-file vs.tt.config.ts --record --key f48ea33b-7d72-4a9a-b6ad-d28612774511 --parallel",
        "open:vs:marketing": "cypress open --project ./src/Vshred/Marketing_Funnels --config-file vs.marketing.config.ts",
        "test:vs:marketing:smoke": "cypress run --project ./src/Vshred/Marketing_Funnels --config-file vs.marketing.config.ts --env tags=@smoke,filterSpecs=true --record --key e90334f9-74d9-43e6-b36f-f69964bfa0c4  --parallel",
        "test:vs:marketing:all": "cypress run --project ./src/Vshred/Marketing_Funnels --config-file vs.marketing.config.ts --record --key e90334f9-74d9-43e6-b36f-f69964bfa0c4  --parallel",
        "test:vs:marketing:blog": "cypress run --project ./src/Vshred/Marketing_Funnels --config-file vs.marketing.config.ts --env tags=@blog,filterSpecs=true --record --key e90334f9-74d9-43e6-b36f-f69964bfa0c4  --parallel",
        "lint": "yarn cache clean && eslint . --ext .js,.ts",
        "lint:fix": "yarn lint --fix",
        "format": "prettier --write **/*.{js,ts}"
    },
    "dependencies": {
        "@badeball/cypress-cucumber-preprocessor": "^18.0.6",
        "@bahmutov/cypress-esbuild-preprocessor": "^2.2.0",
        "@testing-library/cypress": "^10.0.1",
        "@types/mysql": "^2.15.21",
        "@types/node": "^20.6.2",
        "cypress": "^13.17.0",
        "cypress-file-upload": "^5.0.8",
        "cypress-plugin-steps": "^1.2.1",
        "cypress-real-events": "^1.15.0",
        "esbuild": "^0.19.3",
        "jimp": "^0.22.10",
        "mysql2": "^3.6.1",
        "node-ssh": "^13.1.0",
        "otplib": "^12.0.1",
        "pg-promise": "11.5.4",
        "rimraf": "^5.0.1",
        "typescript": "^5.2.2"
    },
    "devDependencies": {
        "@tsconfig/node16": "^16.1.1",
